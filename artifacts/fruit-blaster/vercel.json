{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "framework": null,

  "installCommand": "echo \"handled by buildCommand (monorepo root install)\"",

  "buildCommand": "cd ../.. && pnpm install --frozen-lockfile && pnpm --filter @workspace/fruit-blaster run build",

  "outputDirectory": "dist/public",

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],

  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin"
        },
        {
          "key": "Cross-Origin-Embedder-Policy",
          "value": "credentialless"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
