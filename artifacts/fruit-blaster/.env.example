# Fruit Blaster AI — environment variables
#
# None of these are required for a standard Vercel deployment; sensible
# defaults are used when unset. They only matter for local/custom hosting.

# Port the Vite dev/preview server binds to. Vercel ignores this (static build).
PORT=5173

# Base path the app is served from. Leave unset ("/") for a standalone Vercel
# deployment. Only needed when embedding the app under a sub-path (e.g. the
# Replit workspace's path-based artifact routing).
BASE_PATH=/
